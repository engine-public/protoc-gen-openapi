{
  "components": {
    "schemas": {
      "Order": {
        "properties": {
          "id": {
            "type": "string"
          },
          "payment": {
            "$ref": "#/components/schemas/PaymentMethod"
          },
          "priority": {
            "description": "The priority level of a shipment.\nThis enum carries inline = true, so it is always inlined regardless of the\ninlineEnums compiler option.",
            "enum": [
              "PRIORITY_UNSET",
              "STANDARD",
              "EXPRESS",
              "OVERNIGHT"
            ],
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          }
        },
        "type": "object"
      },
      "OrderStatus": {
        "description": "The lifecycle status of an order.\n\n- `UNSET` — UNSET is the proto3 conventional default value (number = 0).\n\n- `PENDING` — Order has been received and is awaiting processing.\n\n  Sometimes an enum comment might be multi-line. What happens then?\n\n- `CONFIRMED` — Order has been accepted and payment verified.\n\n- `SHIPPED` — Order has been handed off to the carrier and is in transit.\n\n- `CANCELLED` — Order was voided before or during fulfillment.",
        "enum": [
          "UNSET",
          "PENDING",
          "CONFIRMED",
          "SHIPPED",
          "CANCELLED"
        ],
        "type": "string"
      },
      "PaymentMethod": {
        "description": "The payment instrument used to complete the transaction.",
        "enum": [
          "PAYMENT_UNSET",
          "CREDIT_CARD",
          "DEBIT_CARD",
          "BANK_TRANSFER"
        ],
        "type": "string"
      },
      "ReturnReason": {
        "description": "The reason a return was initiated.\nThis enum carries inline = false, so it is always a component schema\nregardless of the inlineEnums compiler option.",
        "enum": [
          "REASON_UNSET",
          "DAMAGED",
          "WRONG_ITEM",
          "NO_LONGER_NEEDED"
        ],
        "type": "string"
      },
      "ReturnRequest": {
        "properties": {
          "affectedStatuses": {
            "description": "Per-value suppress = false keeps REASON_UNSET visible even when\n suppressDefaultEnumValues = true is set globally.",
            "items": {
              "$ref": "#/components/schemas/OrderStatus"
            },
            "type": "array"
          },
          "orderId": {
            "type": "string"
          },
          "reason": {
            "$ref": "#/components/schemas/ReturnReason"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Enums Example API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/orders/{id}": {
      "get": {
        "description": "Retrieve an order by its identifier.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Retrieve an order by its identifier."
      }
    },
    "/returns": {
      "post": {
        "description": "Create a new return request.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReturnRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReturnRequest"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Create a new return request."
      }
    }
  }
}
