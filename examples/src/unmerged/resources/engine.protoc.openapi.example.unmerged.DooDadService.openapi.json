{
  "components": {
    "schemas": {
      "DooDad": {
        "description": "A canonical representation of an Umbrella Corporation Doo-Dad",
        "properties": {
          "id": {
            "description": "The unique identifier of this DooDad",
            "format": "int64",
            "type": "integer"
          },
          "isDoodad": {
            "description": "If true, this DooDad is, in fact, also a DooDad",
            "type": "boolean"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "description": "CRUD Operations on DooDads",
    "title": "DooDadService",
    "version": "22.33.44"
  },
  "openapi": "3.1.0",
  "paths": {
    "/doodad": {
      "get": {
        "description": "List all DooDads in the system",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DooDad"
                  },
                  "type": "array"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "List all DooDads in the system"
      }
    },
    "/doodad/{doodad_id}": {
      "get": {
        "description": "Retrieve a single DooDad by its id",
        "parameters": [
          {
            "in": "path",
            "name": "doodad_id",
            "required": true,
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DooDad"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Retrieve a single DooDad by its id"
      }
    }
  }
}
