  "info" : {
    "title" : "Service Ordering Example API",
    "version" : "1.0.0"
  },
  "tags" : [ {
    "name" : "BetaService",
    "description" : "Source-position 1 — explicit `index_order = -1` places it ahead of every un-annotated\n service.  Negative indices are intended for exactly this case."
  }, {
    "name" : "AlphaService",
    "description" : "Source-position 0 — no `index_order`, so it falls into its encounter ordinal (0)."
  }, {
    "name" : "EpsilonService",
    "description" : "Source-position 4 — explicit `index_order = 0` collides with AlphaService's implicit\n ordinal of 0.  The compiler logs a WARN naming both services and falls back to source\n order; AlphaService keeps the earlier slot because it appears first in source."
  }, {
    "name" : "GammaService",
    "description" : "Source-position 2 — no annotation, so it sorts at ordinal 2.  Sparse: nothing fills the\n gap between Alpha (0) and Gamma (10) other than this one."
  }, {
    "name" : "DeltaService",
    "description" : "Source-position 3 — explicit `index_order = 10` pushes it well past the un-annotated tail."
  } ],
