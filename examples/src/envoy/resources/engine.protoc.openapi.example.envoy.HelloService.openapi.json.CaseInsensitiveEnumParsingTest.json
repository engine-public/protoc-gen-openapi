          }
        }
      },
      "Greeting" : {
        "type" : "string",
        "description" : "The type of greeting to use.\n\n- `greeting_unspecified`\n\n- `greeting_hello` — A formal hello greeting.\n\n- `greeting_hi` — A casual hi greeting.",
        "enum" : [ "greeting_unspecified", "greeting_hello", "greeting_hi" ]
      }
    }
  }
