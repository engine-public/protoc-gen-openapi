{
  "components": {
    "schemas": {
      "Greeting": {
        "description": "The type of greeting to use.\n\n- `GREETING_HELLO` — A formal hello greeting.\n\n- `GREETING_HI` — A casual hi greeting.",
        "enum": [
          "GREETING_UNSPECIFIED",
          "GREETING_HELLO",
          "GREETING_HI"
        ],
        "type": "string"
      },
      "HelloRequest": {
        "properties": {
          "greetingType": {
            "$ref": "#/components/schemas/Greeting"
          },
          "yourName": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "HelloResponse": {
        "properties": {
          "greeting": {
            "$ref": "#/components/schemas/Greeting"
          },
          "replyMessage": {
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "title": "HelloService",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/hello": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HelloRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "format": "int32",
                      "type": "integer"
                    },
                    "details": {
                      "items": {
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Error"
          }
        }
      }
    },
    "/hellos": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HelloRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "format": "int32",
                      "type": "integer"
                    },
                    "details": {
                      "items": {
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Error"
          }
        }
      }
    }
  }
}
