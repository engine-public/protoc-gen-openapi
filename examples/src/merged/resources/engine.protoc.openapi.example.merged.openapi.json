{
  "components": {
    "schemas": {
      "Widget": {
        "description": "A canonical representation of an ACME Corp. Widget",
        "properties": {
          "id": {
            "description": "The unique identifier of this widget",
            "format": "int64",
            "type": "integer"
          },
          "isDoodad": {
            "description": "If true, this widget is, in fact, also a DooDad",
            "type": "boolean"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "summary": "Shows multiple Protobuf services merged into a single OpenAPI spec",
    "title": "Example: Merged Proto Services",
    "version": "1.2.3"
  },
  "openapi": "3.1.0",
  "paths": {
    "/widget": {
      "get": {
        "description": "List all widgets in the system",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Widget"
                  },
                  "type": "array"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "List all widgets in the system",
        "tags": [
          "WidgetService",
          "foo",
          "bar",
          "baz"
        ]
      },
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Widget"
                }
              }
            },
            "description": "OK"
          }
        },
        "tags": [
          "SecondaryService"
        ]
      }
    },
    "/widget/{widget_id}": {
      "get": {
        "description": "Retrieve a single widget by its id",
        "parameters": [
          {
            "in": "path",
            "name": "widget_id",
            "required": true,
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Widget"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Retrieve a single widget by its id",
        "tags": [
          "WidgetService",
          "foo",
          "bar",
          "baz"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "https://merged.example.com"
    }
  ],
  "tags": [
    {
      "description": "This guy does some really heavy stuff.",
      "name": "SecondaryService"
    },
    {
      "description": "CRUD Operations on Widgets",
      "name": "WidgetService"
    }
  ]
}
