{
  "components": {
    "schemas": {
      "Greeting": {
        "description": "The type of greeting to use.\n\n- `greeting_unspecified`\n\n- `greeting_hello` — A formal hello greeting.\n\n- `greeting_hi` — A casual hi greeting.",
        "enum": [
          "greeting_unspecified",
          "greeting_hello",
          "greeting_hi"
        ],
        "type": "string"
      },
      "HelloRequest": {
        "properties": {
          "greetingType": {
            "$ref": "#/components/schemas/Greeting"
          },
          "yourName": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "HelloResponse": {
        "properties": {
          "greeting": {
            "$ref": "#/components/schemas/Greeting"
          },
          "replyMessage": {
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "title": "HelloService",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/hello": {
      "post": {
        "operationId": "HelloService_SayHello",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HelloRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                }
              }
            },
            "description": "OK"
          }
        }
      }
    },
    "/hellos": {
      "post": {
        "operationId": "HelloService_StreamHellos",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HelloRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                }
              }
            },
            "description": "OK"
          }
        }
      }
    }
  }
}
